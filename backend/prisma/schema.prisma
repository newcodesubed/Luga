datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String         @map("password_hash")
  createdAt     DateTime       @default(now()) @map("created_at")
  clothingItems ClothingItem[]
  outfits       Outfit[]

  @@map("users") // Maps the Prisma model to lowercase_plural database table
}

model ClothingItem {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  imageUrl      String       @map("image_url")
  category      String
  subCategory   String?      @map("sub_category")
  primaryColor  String       @map("primary_color")
  aiDescription String?      @map("ai_description")
  createdAt     DateTime     @default(now()) @map("created_at")
  
  // Relations
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems   OutfitItem[]

  @@index([userId, category]) // Composite Index for fast lookups
  @@map("clothing_items")
}

model Outfit {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  name          String
  occasion      String
  isAiGenerated Boolean      @default(false) @map("is_ai_generated")
  createdAt     DateTime     @default(now()) @map("created_at")
  deletedAt     DateTime?    @map("deleted_at") // For Soft Deletes

  // Relations
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems   OutfitItem[]

  @@map("outfits")
}

model OutfitItem {
  outfitId       String       @map("outfit_id")
  clothingItemId String       @map("clothing_item_id")

  // Relations
  outfit         Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  clothingItem   ClothingItem @relation(fields: [clothingItemId], references: [id], onDelete: Cascade)

  @@id([outfitId, clothingItemId]) // Composite Primary Key (prevents duplicate items in an outfit)
  @@map("outfit_items")
}
